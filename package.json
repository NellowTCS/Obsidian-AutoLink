{
	"name": "autolink",
	"version": "1.0.4",
	"description": "Automatically creates backlinks from and to notes with easy customizability.",
	"main": "dist/main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint \"src/**/*.{ts,js}\"",
		"make-pretty": "prettier --write \"src/**/*.{ts,js,json,md}\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/jquery": "^4.0.1",
		"@types/node": "^25.9.1",
		"@typescript-eslint/eslint-plugin": "8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"@vitest/coverage-v8": "^4.1.8",
		"builtin-modules": "5.2.0",
		"esbuild": "0.28.1",
		"eslint": "^10.4.1",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"obsidian": "1.13.0",
		"prettier": "^3.8.3",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"vitest": "^4.1.8"
	}
}
